{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "cloudwatch", "name": "CloudWatch", "version": "1.0.0" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": { "type": "cloudwatch", "uid": "cloudwatch-ds" },
        "enable": true,
        "expr": "",
        "hide": false,
        "iconColor": "red",
        "name": "Anomaly Events",
        "target": {
          "dimensions": { "Pipeline": "LogAnomalyDetector" },
          "expression": "",
          "highResolution": false,
          "id": "",
          "matchExact": true,
          "metricEditorMode": 0,
          "metricName": "IsAnomaly",
          "metricQueryType": 0,
          "namespace": "LogAnomalyDetector",
          "period": "60",
          "queryMode": "Metrics",
          "refId": "Anno",
          "region": "default",
          "statistic": "Maximum"
        },
        "titleFormat": "🚨 Anomaly",
        "type": "cloudwatch"
      }
    ]
  },
  "description": "Real-time log anomaly detection powered by Isolation Forest and Z-Score baseline. Monitors request volume, error rates, latency, and anomaly scores from AWS CloudWatch.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 20,
      "title": "📊 Traffic Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "cloudwatch", "uid": "cloudwatch-ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "alias": "Request Volume",
          "dimensions": { "Pipeline": "LogAnomalyDetector" },
          "matchExact": true,
          "metricName": "RequestVolume",
          "namespace": "LogAnomalyDetector",
          "period": "60",
          "queryMode": "Metrics",
          "refId": "A",
          "region": "default",
          "statistic": "Sum"
        }
      ],
      "title": "Request Volume (per minute)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "cloudwatch", "uid": "cloudwatch-ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "max": 1,
          "min": 0,
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.03 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "alias": "Error Rate",
          "dimensions": { "Pipeline": "LogAnomalyDetector" },
          "matchExact": true,
          "metricName": "ErrorRate",
          "namespace": "LogAnomalyDetector",
          "period": "60",
          "queryMode": "Metrics",
          "refId": "A",
          "region": "default",
          "statistic": "Average"
        }
      ],
      "title": "Error Rate % (threshold: 5%)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 21,
      "title": "⏱ Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "cloudwatch", "uid": "cloudwatch-ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 10 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "alias": "Avg Latency",
          "dimensions": { "Pipeline": "LogAnomalyDetector" },
          "matchExact": true,
          "metricName": "AvgLatency",
          "namespace": "LogAnomalyDetector",
          "period": "60",
          "queryMode": "Metrics",
          "refId": "A",
          "region": "default",
          "statistic": "Average"
        },
        {
          "alias": "P95 Latency",
          "dimensions": { "Pipeline": "LogAnomalyDetector" },
          "matchExact": true,
          "metricName": "P95Latency",
          "namespace": "LogAnomalyDetector",
          "period": "60",
          "queryMode": "Metrics",
          "refId": "B",
          "region": "default",
          "statistic": "Average"
        }
      ],
      "title": "Avg & P95 Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "cloudwatch", "uid": "cloudwatch-ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          },
          "mappings": []
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "id": 4,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "title": "Current P95 Latency",
      "type": "gauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 22,
      "title": "🤖 Anomaly Detection",
      "type": "row"
    },
    {
      "datasource": { "type": "cloudwatch", "uid": "cloudwatch-ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 25 },
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": -0.1 },
              { "color": "red", "value": -0.3 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 19 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" },
        "thresholdsStyle": { "mode": "line+area" }
      },
      "targets": [
        {
          "alias": "Anomaly Score",
          "dimensions": { "Model": "IsolationForest" },
          "matchExact": true,
          "metricName": "AnomalyScore",
          "namespace": "LogAnomalyDetector",
          "period": "60",
          "queryMode": "Metrics",
          "refId": "A",
          "region": "default",
          "statistic": "Average"
        }
      ],
      "title": "Anomaly Score Timeline (threshold: -0.1)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "cloudwatch", "uid": "cloudwatch-ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "green", "index": 0, "text": "Normal" }, "1": { "color": "red", "index": 1, "text": "ANOMALY" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "id": 6,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "text": {}
      },
      "title": "Current Anomaly State",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 23,
      "title": "🚨 Alert Feed",
      "type": "row"
    },
    {
      "datasource": { "type": "cloudwatch", "uid": "cloudwatch-ds" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "displayMode": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "IsAnomaly" }, "properties": [{ "id": "custom.displayMode", "value": "color-background" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "id": 7,
      "options": {
        "footer": { "enablePagination": true },
        "showHeader": true,
        "sortBy": [{ "displayName": "Time", "desc": true }]
      },
      "targets": [
        {
          "alias": "Failed Auth",
          "dimensions": { "Pipeline": "LogAnomalyDetector" },
          "matchExact": true,
          "metricName": "FailedAuthCount",
          "namespace": "LogAnomalyDetector",
          "period": "60",
          "queryMode": "Metrics",
          "refId": "A",
          "region": "default",
          "statistic": "Sum"
        }
      ],
      "title": "Failed Auth Attempts (per minute)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["anomaly-detection", "cloudwatch", "ml"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Log Anomaly Detector",
  "uid": "log-anomaly-detector",
  "version": 1,
  "weekStart": ""
}
