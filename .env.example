# ─── AWS Credentials ────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# ─── CloudWatch ──────────────────────────────────────────────────────────────
CLOUDWATCH_LOG_GROUP=/log-anomaly-detector/app
CLOUDWATCH_LOG_STREAM=app-stream
CLOUDWATCH_METRICS_NAMESPACE=LogAnomalyDetector

# ─── SNS ─────────────────────────────────────────────────────────────────────
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:log-anomaly-alerts

# ─── S3 ──────────────────────────────────────────────────────────────────────
S3_BUCKET=log-anomaly-detector-models

# ─── Pipeline Config ─────────────────────────────────────────────────────────
ANOMALY_THRESHOLD=-0.1          # IsolationForest decision_function cutoff
ZSCORE_THRESHOLD=3.0            # Standard deviations for Z-Score baseline
WINDOW_MINUTES=1                # Feature aggregation window size
POLL_INTERVAL_SECONDS=60        # How often the pipeline polls for new logs
ALERT_COOLDOWN_MINUTES=10       # Suppress duplicate alerts within this window

# ─── Mode ────────────────────────────────────────────────────────────────────
MOCK_MODE=false                 # Set to true to disable real AWS calls
LOG_LEVEL=INFO
